<aside class="cookie-banner" data-cookie-banner hidden>
  <div class="cookie-banner__inner site-shell">
    <div class="section-frame cookie-banner__panel p-5 md:p-6">
      <div class="space-y-4">
        <p class="eyebrow">Cookies</p>
        <p class="cookie-banner__title">Configura qué cookies quieres permitir en esta web.</p>
        <p class="cookie-banner__copy">
          Usamos cookies técnicas para que la web funcione correctamente y puedes decidir si también permites
          cookies de preferencias, analítica o marketing. Puedes consultar más detalle en la
          <a href="/politica-cookies" class="cookie-banner__link"> política de cookies</a>.
        </p>
      </div>

      <div class="cookie-banner__preferences mt-6" data-cookie-preferences-panel>
        <label class="cookie-option">
          <div>
            <span class="cookie-option__title">Cookies técnicas</span>
            <span class="cookie-option__copy">Necesarias para el funcionamiento básico de la web. Siempre activas.</span>
          </div>
          <input type="checkbox" checked disabled />
        </label>

        <label class="cookie-option">
          <div>
            <span class="cookie-option__title">Preferencias</span>
            <span class="cookie-option__copy">Recuerdan opciones como idioma, interfaz o configuración del usuario.</span>
          </div>
          <input type="checkbox" data-cookie-option="preferences" />
        </label>

        <label class="cookie-option">
          <div>
            <span class="cookie-option__title">Analítica</span>
            <span class="cookie-option__copy">Ayudan a entender el uso general de la web para mejorar navegación y rendimiento.</span>
          </div>
          <input type="checkbox" data-cookie-option="analytics" />
        </label>

        <label class="cookie-option">
          <div>
            <span class="cookie-option__title">Marketing</span>
            <span class="cookie-option__copy">Permiten medir campañas y mostrar comunicaciones más relevantes si se usan herramientas externas.</span>
          </div>
          <input type="checkbox" data-cookie-option="marketing" />
        </label>
      </div>

      <div class="cookie-banner__actions mt-6 flex flex-col gap-3 lg:flex-row">
        <button type="button" class="button-primary" data-cookie-accept-all>Aceptar todas</button>
        <button type="button" class="button-secondary" data-cookie-save>Guardar selección</button>
        <button type="button" class="button-secondary" data-cookie-reject>Rechazar opcionales</button>
      </div>

      <div class="mt-5 text-xs uppercase tracking-[0.14em] text-[rgba(254,251,164,0.48)]">
        <a href="/politica-cookies" class="cookie-banner__link">Política de cookies</a>
        <span> · </span>
        <a href="/politica-privacidad" class="cookie-banner__link">Política de privacidad</a>
        <span> · </span>
        <a href="/aviso-legal" class="cookie-banner__link">Aviso legal</a>
      </div>
    </div>
  </div>
</aside>
