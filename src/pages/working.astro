---
import Layout from "@/layouts/Layout.astro";
---

<Layout
  title="Actualizando proyectos | SQ Studio"
  description="SQ Studio está ampliando esta sección con nuevos trabajos."
  url="https://sqstudio.es/working"
  robots="noindex, follow"
>
  <section class="page-hero">
    <div class="site-shell">
      <div class="section-frame p-8 md:p-12" data-reveal>
        <p class="eyebrow">En actualización</p>
        <h1 class="section-title mt-6 text-[var(--sq-cream)]">Estamos preparando esta sección para mostrar el trabajo con el nivel que merece.</h1>
        <p class="section-copy mt-6">
          En lugar de enseñar un portfolio incompleto, preferimos reorganizarlo bien y publicarlo con una narrativa más sólida.
        </p>
        <div class="mt-8">
          <a href="/" class="button-primary">Volver al inicio</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
