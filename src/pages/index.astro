---
import Layout from "@/layouts/Layout.astro";
import LeadMagnet from "@/components/LeadMagnet.astro";
import heroImage from "@/assets/web.png";
import icon1 from "@/assets/icon1.png";
import icon2 from "@/assets/icon2.png";
import icon3 from "@/assets/icon3.png";
import icon4 from "@/assets/icon4.png";
import icon5 from "@/assets/icon5.png";
import icon6 from "@/assets/icon6.png";
import logo1 from "@/assets/logos/logo1.svg";
import logo2 from "@/assets/logos/logo2.svg";
import logo3 from "@/assets/logos/logo3.svg";
import logo4 from "@/assets/logos/logo4.svg";
import logo5 from "@/assets/logos/logo5.svg";
import logo6 from "@/assets/logos/logo6.svg";
import logo8 from "@/assets/logos/logo8.svg";
import logo9 from "@/assets/logos/logo9.svg";
import logo10 from "@/assets/logos/logo10.svg";
import logo11 from "@/assets/logos/logo11.svg";

const services = [
  {
    icon: icon1.src,
    title: "Branding estratégico",
    copy: "Arquitectura de marca, narrativa visual y sistemas que sostienen el crecimiento de empresas y marcas con ambición.",
    href: "/branding",
    cta: "Explorar branding estratégico",
  },
  {
    icon: icon2.src,
    title: "Diseño web profesional",
    copy: "Webs rápidas, claras y orientadas a conversión. Diseño y desarrollo alineados desde el inicio.",
    href: "/diseno-web",
    cta: "Ver diseño web profesional",
  },
  {
    icon: icon3.src,
    title: "Diseño gráfico y editorial",
    copy: "Piezas con criterio compositivo, jerarquía clara y una lectura más estratégica que promocional.",
    href: "/diseno-grafico",
    cta: "Ver diseño gráfico",
  },
  {
    icon: icon4.src,
    title: "Dirección de arte",
    copy: "Unificamos imagen, tono, ritmo y ejecución para que cada punto de contacto refuerce el mismo posicionamiento.",
    href: "/diseno-grafico",
    cta: "Explorar dirección de arte",
  },
  {
    icon: icon5.src,
    title: "Contenido visual para marcas",
    copy: "Assets para lanzamientos, redes y campañas que elevan percepción, consistencia y reconocimiento.",
    href: "/redes",
    cta: "Ver contenido visual",
  },
  {
    icon: icon6.src,
    title: "Consultoría creativa",
    copy: "Detectamos fricción, afinamos el mensaje y definimos qué conviene construir primero para vender mejor.",
    href: "/contacto",
    cta: "Solicitar una revisión",
  },
];

const logos = [logo1, logo2, logo3, logo4, logo5, logo6, logo8, logo9, logo10, logo11];
const featuredProjects = [
  {
    href: "/proyectos#ader-la-palma",
    image: "/Fotos/foto1.png",
    label: "Cartelería",
    title: "ADER La Palma · sistema gráfico para Emprende Rural.",
    alt: "Cartelería desarrollada para ADER La Palma",
  },
  {
    href: "/proyectos#entrena-facil",
    image: "/Fotos/foto18.png",
    label: "Web",
    title: "Entrena Fácil · diseño web claro y funcional.",
    alt: "Diseño web realizado para Entrena Fácil",
  },
  {
    href: "/proyectos#catavs",
    image: "/Fotos/foto43.png",
    label: "Identidad gráfica",
    title: "CATAVS · sistema visual completo para congreso.",
    alt: "Identidad gráfica creada para el congreso CATAVS",
  },
];
---

<Layout
  title="SQ Studio | Diseño web profesional, branding estratégico y diseño gráfico"
  description="SQ Studio es un estudio estratégico de branding, diseño gráfico y diseño web profesional para marcas y negocios en España."
>
  <section class="hero-panel">
    <div class="hero-panel__media">
      <img
        src={heroImage.src}
        alt="Pantalla de proyecto digital de SQ Studio"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        width={heroImage.width}
        height={heroImage.height}
      />
    </div>

    <div class="site-shell hero-panel__grid">
      <div class="space-y-8" data-reveal>
        <p class="display-kicker">SQ Studio · Branding estratégico, diseño web y diseño gráfico</p>
        <h1 class="display-title max-w-5xl text-[var(--sq-cream)]">
          Estudio estratégico de branding, diseño gráfico y diseño web profesional.
        </h1>
        <p class="section-copy max-w-2xl">
          Ayudamos a marcas y negocios en España a ordenar su posicionamiento, mejorar su presencia digital
          y convertir mejor con branding estratégico, diseño gráfico y desarrollo web a medida.
        </p>
       
        <div class="flex flex-col gap-3 sm:flex-row">
          <a href="/contacto" class="button-primary">Solicitar una auditoría</a>
          <a href="/proyectos" class="button-secondary">Ver proyectos</a>
        </div>
      </div>

      <div class="section-frame p-6 md:p-8" data-reveal>
        <p class="eyebrow">Qué hacemos</p>
        <div class="editorial-list mt-6">
          <div class="editorial-item">
            <strong>Branding estratégico</strong>
            <p>Definimos posicionamiento, narrativa y sistema visual para que la marca gane claridad y autoridad.</p>
          </div>
          <div class="editorial-item">
            <strong>Diseño web profesional</strong>
            <p>Diseñamos y desarrollamos webs rápidas, accesibles y orientadas a captación sin perder sofisticación.</p>
          </div>
          <div class="editorial-item">
            <strong>Diseño gráfico que sostiene negocio</strong>
            <p>Creamos piezas, campañas y soportes que refuerzan percepción, consistencia y decisión de compra.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-pad">
    <div class="site-shell grid gap-8 md:grid-cols-[0.9fr_1.1fr] md:items-end">
      <div class="space-y-5" data-reveal>
        <p class="eyebrow">Confianza</p>
        <h2 class="section-title text-[var(--sq-cream)]">Trabajamos para marcas y negocios que necesitan vender con más claridad y mejor percepción.</h2>
      </div>
      <div class="grid-stats" data-reveal>
        <div class="stat-card">
          <strong>Branding</strong>
          <span>Branding estratégico para empresas que necesitan una marca más sólida y diferenciada.</span>
        </div>
        <div class="stat-card">
          <strong>Web</strong>
          <span>Diseño web profesional y desarrollo web a medida en una misma mesa.</span>
        </div>
        <div class="stat-card">
          <strong>Contenido</strong>
          <span>Diseño gráfico, campañas y activos editoriales con criterio visual y foco comercial.</span>
        </div>
      </div>
    </div>

    <div class="site-shell mt-10" data-reveal>
      <div class="section-frame p-6 md:p-8">
        <div class="logo-row">
          {logos.map((logo) => <img src={logo.src} alt="Cliente SQ Studio" loading="lazy" />)}
        </div>
      </div>
    </div>
  </section>

  <LeadMagnet
    eyebrow="Auditoría"
    title="Si quieres detectar qué está frenando tu marca o tu web, podemos revisarlo."
    description="Analizamos estructura, claridad del mensaje, percepción visual y puntos de fricción para ayudarte a decidir qué conviene mejorar primero."
    primaryHref="/contacto"
    primaryLabel="Solicitar una auditoría"
    secondaryHref="/diseno-web"
    secondaryLabel="Ver diseño web profesional"
  />

  <section class="section-pad">
    <div class="site-shell space-y-10">
      <div class="space-y-5" data-reveal>
        <p class="eyebrow">Servicios</p>
        <h2 class="section-title text-[var(--sq-cream)]">Servicios de branding, diseño gráfico y desarrollo web orientados a resultados.</h2>
        <p class="section-copy">
          SQ Studio opera como estudio estratégico para marcas que necesitan una presencia más clara,
          una web mejor enfocada y un sistema visual capaz de sostener crecimiento real.
        </p>
      </div>

      <div class="feature-grid" data-reveal>
        {services.map((service, index) => (
          <article
            class={`surface-card ${index === 0 || index === 5 ? "md:col-span-6" : "md:col-span-3"}`}
          >
            <img
              src={service.icon}
              alt={service.title}
              class="service-icon mb-6 h-16 w-16 object-contain"
              loading="lazy"
            />
            <h3>{service.title}</h3>
            <p>{service.copy}</p>
            <a href={service.href} class="mt-6 inline-flex text-sm font-bold uppercase tracking-[0.12em] text-[var(--sq-gold)] transition hover:text-[var(--sq-orange)]">
              {service.cta}
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-pad">
    <div class="site-shell space-y-10">
      <div class="grid gap-6 md:grid-cols-[0.8fr_1.2fr] md:items-end">
        <div class="space-y-5" data-reveal>
          <p class="eyebrow">Proyectos</p>
          <h2 class="section-title text-[var(--sq-cream)]">Proyectos reales de diseño web, branding estratégico y diseño gráfico.</h2>
        </div>
        <p class="section-copy" data-reveal>
          La selección reúne trabajos para instituciones, congresos, marcas y programas formativos,
          manteniendo el mismo criterio visual en soportes físicos, digitales e institucionales.
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-[1.2fr_0.8fr]" data-reveal>
        <a href={featuredProjects[0].href} class="media-card">
          <img src={featuredProjects[0].image} alt={featuredProjects[0].alt} loading="lazy" />
          <div class="media-card__overlay">
            <span class="media-card__label">{featuredProjects[0].label}</span>
            <h3 class="media-card__title">{featuredProjects[0].title}</h3>
          </div>
        </a>

        <div class="grid gap-6">
          <a href={featuredProjects[1].href} class="media-card min-h-[13rem]">
            <img src={featuredProjects[1].image} alt={featuredProjects[1].alt} loading="lazy" />
            <div class="media-card__overlay">
              <span class="media-card__label">{featuredProjects[1].label}</span>
              <h3 class="media-card__title">{featuredProjects[1].title}</h3>
            </div>
          </a>

          <a href={featuredProjects[2].href} class="media-card min-h-[13rem]">
            <img src={featuredProjects[2].image} alt={featuredProjects[2].alt} loading="lazy" />
            <div class="media-card__overlay">
              <span class="media-card__label">{featuredProjects[2].label}</span>
              <h3 class="media-card__title">{featuredProjects[2].title}</h3>
            </div>
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="section-pad">
    <div class="site-shell grid gap-6 md:grid-cols-2">
      <div class="section-frame p-6 md:p-8" data-reveal>
        <p class="eyebrow">Filosofía</p>
        <h2 class="section-title mt-4 text-[var(--sq-cream)]">Menos ornamento. Más decisión.</h2>
        <p class="section-copy mt-6">
          La referencia premium aquí no está en copiar una web externa, sino en adoptar una lógica:
          aire, tensión tipográfica, ritmo vertical, control del contraste y una ejecución visual sin ruido.
        </p>
      </div>

      <div class="section-frame p-6 md:p-8" data-reveal>
        <p class="eyebrow">Proceso</p>
        <div class="editorial-list mt-6">
          <div class="editorial-item">
            <strong>01 · Diagnóstico</strong>
            <p>Detectamos qué resta claridad y qué limita la percepción actual de la marca.</p>
          </div>
          <div class="editorial-item">
            <strong>02 · Sistema</strong>
            <p>Definimos tono visual, jerarquía, grid, activos y patrones reutilizables.</p>
          </div>
          <div class="editorial-item">
            <strong>03 · Lanzamiento</strong>
            <p>Ejecutamos la experiencia final con foco en velocidad, accesibilidad y mantenimiento.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-pad">
    <div class="site-shell grid gap-8 md:grid-cols-[0.9fr_1.1fr] md:items-start">
      <div class="space-y-5" data-reveal>
        <p class="eyebrow">Contacto</p>
        <h2 class="section-title text-[var(--sq-cream)]">Si necesitas branding estratégico o una web profesional, hablemos.</h2>
        <p class="section-copy">
          Cuéntanos qué quieres mejorar: marca, diseño gráfico o desarrollo web. Trabajamos desde Santa Cruz de Tenerife
          para proyectos en España y en remoto.
        </p>
      </div>

      <div class="section-frame p-6 md:p-8" data-reveal>
        <form class="contact-form" action="https://formsubmit.co/saraquintanadg@gmail.com" method="POST">
          <input type="text" name="name" placeholder="Nombre" required />
          <input type="email" name="email" placeholder="Correo electrónico" required />
          <textarea name="message" rows="5" placeholder="Cuéntanos el proyecto" required></textarea>
          <input type="hidden" name="_captcha" value="false" />
          <input type="hidden" name="_next" value="https://sqstudio.es/gracias" />
          <button type="submit" class="button-primary">Enviar solicitud</button>
        </form>
      </div>
    </div>
  </section>
</Layout>
