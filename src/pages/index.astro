---
import Layout from "@/layouts/Layout.astro";
import heroImage from "@/assets/web.png";
import projectDesign from "@/assets/2.webp";
import projectSocial from "@/assets/8.webp";
import icon1 from "@/assets/icon1.png";
import icon2 from "@/assets/icon2.png";
import icon3 from "@/assets/icon3.png";
import icon4 from "@/assets/icon4.png";
import icon5 from "@/assets/icon5.png";
import icon6 from "@/assets/icon6.png";
import logo1 from "@/assets/logos/logo1.svg";
import logo2 from "@/assets/logos/logo2.svg";
import logo3 from "@/assets/logos/logo3.svg";
import logo4 from "@/assets/logos/logo4.svg";
import logo5 from "@/assets/logos/logo5.svg";
import logo6 from "@/assets/logos/logo6.svg";
import logo8 from "@/assets/logos/logo8.svg";
import logo9 from "@/assets/logos/logo9.svg";
import logo10 from "@/assets/logos/logo10.svg";
import logo11 from "@/assets/logos/logo11.svg";

const services = [
  {
    icon: icon1.src,
    title: "Branding estratégico",
    copy: "Arquitectura de marca, narrativa visual y sistemas que sostienen el crecimiento.",
  },
  {
    icon: icon2.src,
    title: "Experiencias web",
    copy: "Sitios rápidos, claros y con presencia. Diseño y desarrollo alineados desde el inicio.",
  },
  {
    icon: icon3.src,
    title: "Editorial y campañas",
    copy: "Piezas con criterio compositivo, jerarquía y una lectura más aspiracional que promocional.",
  },
  {
    icon: icon4.src,
    title: "Dirección de arte",
    copy: "Unificamos imagen, tono, ritmo y ejecución para que cada punto de contacto hable igual de bien.",
  },
  {
    icon: icon5.src,
    title: "Contenido visual",
    copy: "Assets para lanzamientos, redes y campañas que elevan la percepción de marca.",
  },
  {
    icon: icon6.src,
    title: "Consultoría creativa",
    copy: "Detectamos fricción, afinamos el mensaje y definimos qué conviene construir primero.",
  },
];

const logos = [logo1, logo2, logo3, logo4, logo5, logo6, logo8, logo9, logo10, logo11];
---

<Layout
  title="SQ Studio | Estudio creativo y digital premium"
  description="SQ Studio diseña marcas, webs y sistemas visuales con una estética contemporánea, precisa y orientada a negocio."
>
  <section class="hero-panel">
    <div class="hero-panel__media">
      <img src={heroImage.src} alt="Pantalla de proyecto digital de SQ Studio" loading="eager" />
    </div>

    <div class="site-shell hero-panel__grid">
      <div class="space-y-8" data-reveal>
        <p class="display-kicker">SQ Studio · Diseño, branding, web</p>
        <h1 class="display-title max-w-5xl text-[var(--sq-cream)]">
          Marcas y experiencias digitales con presencia premium.
        </h1>
       
        <div class="flex flex-col gap-3 sm:flex-row">
          <a href="/proyectos" class="button-secondary">Ver trabajos</a>
        </div>
      </div>

      <div class="section-frame p-6 md:p-8" data-reveal>
        <p class="eyebrow">Qué hacemos</p>
        <div class="editorial-list mt-6">
          <div class="editorial-item">
            <strong>Diseño con criterio</strong>
            <p>Composición limpia, jerarquía clara y dirección de arte coherente en cada soporte.</p>
          </div>
          <div class="editorial-item">
            <strong>Web con intención</strong>
            <p>Interfaces rápidas, accesibles y pensadas para convertir mejor sin perder sofisticación.</p>
          </div>
          <div class="editorial-item">
            <strong>Marca que se sostiene</strong>
            <p>Sistemas visuales preparados para crecer, no piezas aisladas que caducan rápido.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-pad">
    <div class="site-shell grid gap-8 md:grid-cols-[0.9fr_1.1fr] md:items-end">
      <div class="space-y-5" data-reveal>
        <p class="eyebrow">Confianza</p>
        <h2 class="section-title text-[var(--sq-cream)]">Trabajamos para marcas que necesitan elevar percepción y claridad.</h2>
      </div>
      <div class="grid-stats" data-reveal>
        <div class="stat-card">
          <strong>Branding</strong>
          <span>Sistemas visuales consistentes para marcas nuevas o en fase de salto.</span>
        </div>
        <div class="stat-card">
          <strong>Web</strong>
          <span>Diseño y desarrollo en una misma mesa para evitar soluciones a medias.</span>
        </div>
        <div class="stat-card">
          <strong>Contenido</strong>
          <span>Activos editoriales, campañas y soportes que mantienen el mismo nivel.</span>
        </div>
      </div>
    </div>

    <div class="site-shell mt-10" data-reveal>
      <div class="section-frame p-6 md:p-8">
        <div class="logo-row">
          {logos.map((logo) => <img src={logo.src} alt="Cliente SQ Studio" loading="lazy" />)}
        </div>
      </div>
    </div>
  </section>

  <section class="section-pad">
    <div class="site-shell space-y-10">
      <div class="space-y-5" data-reveal>
        <p class="eyebrow">Servicios</p>
        <h2 class="section-title text-[var(--sq-cream)]">Una oferta compacta, visual y ejecutada con rigor.</h2>
        <p class="section-copy">
          Reestructuramos la propuesta de SQ Studio para que se sienta menos “agencia con cajas” y
          más estudio con dirección, foco y un estándar visual alto.
        </p>
      </div>

      <div class="feature-grid" data-reveal>
        {services.map((service, index) => (
          <article
            class={`surface-card ${index === 0 || index === 5 ? "md:col-span-6" : "md:col-span-3"}`}
          >
            <img
              src={service.icon}
              alt={service.title}
              class="service-icon mb-6 h-16 w-16 object-contain"
              loading="lazy"
            />
            <h3>{service.title}</h3>
            <p>{service.copy}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-pad">
    <div class="site-shell space-y-10">
      <div class="grid gap-6 md:grid-cols-[0.8fr_1.2fr] md:items-end">
        <div class="space-y-5" data-reveal>
          <p class="eyebrow">Proyectos</p>
          <h2 class="section-title text-[var(--sq-cream)]">Casos que priorizan impacto visual, lectura rápida y mejor percepción.</h2>
        </div>
        <p class="section-copy" data-reveal>
          El nuevo enfoque da protagonismo a bloques grandes, imágenes con peso y copy más corto,
          para construir una sensación editorial y tecnológica sin salirse de la identidad cromática actual.
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-[1.2fr_0.8fr]" data-reveal>
        <a href="/diseño" class="media-card">
          <img src={projectDesign.src} alt="Proyecto de diseño de SQ Studio" loading="lazy" />
          <div class="media-card__overlay">
            <span class="media-card__label">Diseño gráfico</span>
            <h3 class="media-card__title">Sistemas visuales que aguantan la mirada.</h3>
          </div>
        </a>

        <div class="grid gap-6">
          <a href="/web" class="media-card min-h-[13rem]">
            <img src={heroImage.src} alt="Proyecto web de SQ Studio" loading="lazy" />
            <div class="media-card__overlay">
              <span class="media-card__label">Web</span>
              <h3 class="media-card__title">Interfaces sobrias y rápidas.</h3>
            </div>
          </a>

          <a href="/redes" class="media-card min-h-[13rem]">
            <img src={projectSocial.src} alt="Proyecto visual para redes de SQ Studio" loading="lazy" />
            <div class="media-card__overlay">
              <span class="media-card__label">Contenido</span>
              <h3 class="media-card__title">Campañas con narrativa y consistencia.</h3>
            </div>
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="section-pad">
    <div class="site-shell grid gap-6 md:grid-cols-2">
      <div class="section-frame p-6 md:p-8" data-reveal>
        <p class="eyebrow">Filosofía</p>
        <h2 class="section-title mt-4 text-[var(--sq-cream)]">Menos ornamento. Más decisión.</h2>
        <p class="section-copy mt-6">
          La referencia premium aquí no está en copiar una web externa, sino en adoptar una lógica:
          aire, tensión tipográfica, ritmo vertical, control del contraste y una ejecución visual sin ruido.
        </p>
      </div>

      <div class="section-frame p-6 md:p-8" data-reveal>
        <p class="eyebrow">Proceso</p>
        <div class="editorial-list mt-6">
          <div class="editorial-item">
            <strong>01 · Diagnóstico</strong>
            <p>Detectamos qué resta claridad y qué limita la percepción actual de la marca.</p>
          </div>
          <div class="editorial-item">
            <strong>02 · Sistema</strong>
            <p>Definimos tono visual, jerarquía, grid, activos y patrones reutilizables.</p>
          </div>
          <div class="editorial-item">
            <strong>03 · Lanzamiento</strong>
            <p>Ejecutamos la experiencia final con foco en velocidad, accesibilidad y mantenimiento.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-pad">
    <div class="site-shell grid gap-8 md:grid-cols-[0.9fr_1.1fr] md:items-start">
      <div class="space-y-5" data-reveal>
        <p class="eyebrow">Contacto</p>
        <h2 class="section-title text-[var(--sq-cream)]">Si tu marca necesita verse al nivel de tu ambición, hablemos.</h2>
        <p class="section-copy">
          Cuéntanos en qué punto estás y qué percepción quieres construir. La respuesta debe sentirse
          más precisa, más premium y más coherente en todos tus canales.
        </p>
      </div>

      <div class="section-frame p-6 md:p-8" data-reveal>
        <form class="contact-form" action="https://formsubmit.co/saraquintanadg@gmail.com" method="POST">
          <input type="text" name="name" placeholder="Nombre" required />
          <input type="email" name="email" placeholder="Correo electrónico" required />
          <textarea name="message" rows="5" placeholder="Cuéntanos el proyecto" required></textarea>
          <input type="hidden" name="_captcha" value="false" />
          <input type="hidden" name="_next" value="https://sqstudio.es/gracias" />
          <button type="submit" class="button-primary">Enviar solicitud</button>
        </form>
      </div>
    </div>
  </section>
</Layout>
