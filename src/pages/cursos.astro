---
import Layout from "@/layouts/Layout.astro";

const courses = [
  {
    title: "Branding para emprendedores",
    copy: "Construye una base visual y estratégica sólida antes de escalar comunicación y ventas.",
  },
  {
    title: "Canva con criterio visual",
    copy: "Aprende a diseñar piezas más limpias y profesionales sin caer en soluciones genéricas.",
  },
  {
    title: "Fundamentos de web",
    copy: "Entiende estructura, jerarquía y decisión visual para que una web no solo exista, sino funcione.",
  },
];
---

<Layout
  title="Cursos | SQ Studio"
  description="Cursos y formación de SQ Studio en branding, diseño y fundamentos web."
  url="https://sqstudio.es/cursos"
>
  <section class="page-hero">
    <div class="site-shell page-hero__grid">
      <div class="space-y-6" data-reveal>
        <p class="eyebrow">Cursos</p>
        <h1 class="section-title text-[var(--sq-cream)]">Formación práctica para diseñar con mejor criterio y más intención.</h1>
        <p class="section-copy">
          La página de cursos ahora comparte el mismo tono premium: menos ruido visual, más claridad
          y una presentación que se siente parte del mismo universo de marca.
        </p>
      </div>
      <div class="page-hero__panel" data-reveal>
        <div class="editorial-list">
          <div class="editorial-item">
            <strong>Orientación práctica</strong>
            <p>Contenido pensado para aplicar rápido, no para acumular teoría.</p>
          </div>
          <div class="editorial-item">
            <strong>Estándar visual</strong>
            <p>El objetivo es mejorar criterio, no solo aprender herramientas.</p>
          </div>
          <div class="editorial-item">
            <strong>Lanzamiento</strong>
            <p>Nuevas ediciones y convocatorias se anunciarán aquí.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-pad">
    <div class="site-shell grid gap-6 md:grid-cols-3">
      {courses.map((course) => (
        <article class="surface-card" data-reveal>
          <p class="media-card__label">Próximamente</p>
          <h2 class="mt-4 text-3xl font-bold uppercase leading-none tracking-[-0.05em] text-[var(--sq-cream)]">{course.title}</h2>
          <p class="mt-5">{course.copy}</p>
          <div class="mt-8">
            <span class="button-secondary">Apertura próximamente</span>
          </div>
        </article>
      ))}
    </div>

    <div class="site-shell mt-6 grid gap-6 md:grid-cols-2">
      <article class="section-frame p-6 md:p-8" data-reveal>
        <p class="eyebrow">Para quién</p>
        <p class="mt-6 text-3xl font-bold uppercase leading-none tracking-[-0.05em] text-[var(--sq-cream)] md:text-5xl">
          Emprendedores, equipos pequeños y perfiles creativos que quieren subir el nivel visual de su marca.
        </p>
      </article>
      <article class="section-frame p-6 md:p-8" data-reveal>
        <p class="eyebrow">Acceso</p>
        <p class="section-copy mt-6">
          Si quieres enterarte antes que nadie cuando abramos plazas o nuevas formaciones, escríbenos
          y te avisaremos.
        </p>
        <div class="mt-8">
          <a href="/contacto" class="button-primary">Solicitar aviso</a>
        </div>
      </article>
    </div>
  </section>
</Layout>
