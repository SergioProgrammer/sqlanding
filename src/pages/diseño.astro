---
import Layout from "@/layouts/Layout.astro";
---

<Layout
  title="Diseño gráfico profesional y dirección de arte | SQ Studio"
  description="Diseño gráfico profesional, editorial y dirección de arte para marcas que necesitan piezas claras, memorables y coherentes."
  url="https://sqstudio.es/diseño"
  canonical="https://sqstudio.es/diseno-grafico"
  robots="noindex, follow"
  redirectTo="/diseno-grafico"
>
  <section class="page-hero">
    <div class="site-shell">
      <div class="section-frame p-8 md:p-12" data-reveal>
        <p class="eyebrow">Redirección</p>
        <h1 class="section-title mt-6 text-[var(--sq-cream)]">Esta página se ha movido a diseño gráfico profesional.</h1>
        <p class="section-copy mt-6">
          Si no eres redirigido automáticamente, puedes continuar desde la nueva URL principal del servicio.
        </p>
        <div class="mt-8">
          <a href="/diseno-grafico" class="button-primary">Ir a diseño gráfico profesional</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
