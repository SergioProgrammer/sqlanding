---
import Layout from "@/layouts/Layout.astro";
import LeadMagnet from "@/components/LeadMagnet.astro";

const blocks = [
  {
    title: "Qué hacemos",
    copy: "Desarrollo web a medida para proyectos que necesitan una implementación más fina, rápida y coherente con su sistema visual.",
  },
  {
    title: "Para quién es",
    copy: "Para negocios que no quieren depender de soluciones genéricas cuando la estructura, el rendimiento o la experiencia importan de verdad.",
  },
  {
    title: "Cómo trabajamos",
    copy: "Diseño y desarrollo se resuelven juntos para evitar brechas entre lo que se presenta y lo que realmente funciona.",
  },
];

const faqs = [
  {
    question: "¿Cuándo compensa un desarrollo web a medida?",
    answer: "Compensa cuando la web tiene un papel comercial importante, necesita una estructura específica o debe responder a un posicionamiento de marca más exigente.",
  },
  {
    question: "¿Es solo para proyectos grandes?",
    answer: "No. También puede tener sentido en webs relativamente compactas si el objetivo es captar mejor, cargar rápido y no arrastrar limitaciones de plantilla.",
  },
  {
    question: "¿Se puede combinar con branding o diseño gráfico?",
    answer: "Sí. De hecho, suele dar mejores resultados cuando la parte visual y la parte técnica se plantean como un mismo sistema.",
  },
];

const schemas = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    name: "Desarrollo web a medida",
    serviceType: "Desarrollo web a medida",
    provider: {
      "@type": "ProfessionalService",
      name: "SQ Studio",
      url: "https://sqstudio.es/",
    },
    areaServed: "ES",
    url: "https://sqstudio.es/desarrollo-web",
    description: "Servicio de desarrollo web a medida para marcas y negocios que necesitan velocidad, estructura propia y una implementación coherente con su posicionamiento.",
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Inicio", item: "https://sqstudio.es/" },
      { "@type": "ListItem", position: 2, name: "Desarrollo web", item: "https://sqstudio.es/desarrollo-web" },
    ],
  },
];
---

<Layout
  title="Desarrollo web a medida para marcas y negocios | SQ Studio"
  description="Servicio de desarrollo web a medida para marcas y negocios que necesitan velocidad, estructura propia y una implementación coherente con su posicionamiento."
  url="https://sqstudio.es/desarrollo-web"
  schemas={schemas}
>
  <article>
    <section class="page-hero">
      <div class="site-shell page-hero__grid">
        <div class="space-y-6" data-reveal>
          <p class="eyebrow">Desarrollo web</p>
          <h1 class="section-title text-[var(--sq-cream)]">Desarrollo web a medida para proyectos que necesitan algo más que una plantilla.</h1>
          <p class="section-copy">
            Implementamos webs rápidas, estables y coherentes con la estrategia del negocio, cuidando
            rendimiento, estructura y capacidad de crecimiento desde la base.
          </p>
        </div>

        <div class="page-hero__panel" data-reveal>
          <div class="editorial-list">
            {blocks.map((block) => (
              <div class="editorial-item">
                <strong>{block.title}</strong>
                <p>{block.copy}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="section-pad">
      <div class="site-shell space-y-10">
        <div class="space-y-5" data-reveal>
          <p class="eyebrow">Qué hacemos</p>
          <h2 class="section-title text-[var(--sq-cream)]">Desarrollo ligero, claro y orientado a negocio.</h2>
          <p class="section-copy">
            La implementación no debería deteriorar el diseño ni el SEO. Debe reforzarlos. Por eso trabajamos
            con una lógica donde estructura, velocidad y mantenimiento forman parte del resultado final.
          </p>
        </div>

        <div class="feature-grid" data-reveal>
          <article class="surface-card md:col-span-4">
            <h3>Rendimiento</h3>
            <p>Priorizamos carga rápida, buena base técnica y una experiencia más estable en móvil y escritorio.</p>
          </article>
          <article class="surface-card md:col-span-4">
            <h3>Escalabilidad</h3>
            <p>La web queda preparada para crecer con nuevas páginas, landings y contenido sin romperse.</p>
          </article>
          <article class="surface-card md:col-span-4">
            <h3>Coherencia</h3>
            <p>Lo que se diseña se implementa con el mismo criterio para evitar soluciones a medias.</p>
          </article>
        </div>
      </div>
    </section>

    <section class="section-pad">
      <div class="site-shell grid gap-6 md:grid-cols-2">
        <div class="section-frame p-6 md:p-8" data-reveal>
          <p class="eyebrow">Para quién es</p>
          <h2 class="section-title mt-4 text-[var(--sq-cream)]">Para marcas que necesitan una web más afinada técnica y estratégicamente.</h2>
          <p class="section-copy mt-6">
            Tiene sentido cuando el negocio necesita una base más limpia, un rendimiento mejor o una estructura
            de páginas más adaptada a la captación y al SEO.
          </p>
        </div>

        <div class="section-frame p-6 md:p-8" data-reveal>
          <p class="eyebrow">Cómo trabajamos</p>
          <div class="editorial-list mt-6">
            <div class="editorial-item">
              <strong>01 · Base técnica</strong>
              <p>Definimos una arquitectura sencilla, rápida y mantenible.</p>
            </div>
            <div class="editorial-item">
              <strong>02 · Implementación</strong>
              <p>Traducimos el diseño a una capa de código coherente y estable.</p>
            </div>
            <div class="editorial-item">
              <strong>03 · Optimización</strong>
              <p>Revisamos rendimiento, SEO base y experiencia final antes del lanzamiento.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section-pad">
      <div class="site-shell grid gap-6 md:grid-cols-[1.1fr_0.9fr]">
        <div class="section-frame p-6 md:p-8" data-reveal>
          <p class="eyebrow">Resultados</p>
          <h2 class="section-title mt-4 text-[var(--sq-cream)]">Una web que carga mejor, se entiende mejor y escala mejor.</h2>
          <p class="section-copy mt-6">
            Cuando la implementación está bien resuelta, la web gana en control, velocidad y capacidad para
            sostener campañas, SEO y nuevas páginas sin fricción.
          </p>
          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            <a href="/web" class="button-secondary">Ver enfoque de diseño web</a>
            <a href="/contacto" class="button-primary">Hablar sobre desarrollo a medida</a>
          </div>
        </div>

        <div class="section-frame p-6 md:p-8" data-reveal>
          <p class="eyebrow">FAQ</p>
          <div class="editorial-list mt-6">
            {faqs.map((faq) => (
              <div class="editorial-item">
                <strong>{faq.question}</strong>
                <p>{faq.answer}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <LeadMagnet
      eyebrow="Revisión técnica"
      title="Si la web necesita una base más sólida, lo revisamos."
      description="Podemos evaluar estructura, rendimiento, escalabilidad y margen de mejora para definir si tu proyecto necesita un ajuste ligero o un desarrollo a medida más serio."
      primaryHref="/contacto"
      primaryLabel="Solicitar revisión técnica"
      secondaryHref="/blog/cuanto-tarda-hacer-una-web"
      secondaryLabel="Leer cuánto tarda hacer una web"
    />
  </article>
</Layout>
