---
import Layout from "@/layouts/Layout.astro";
---

<Layout
  title="Contacto | SQ Studio"
  description="Habla con SQ Studio sobre branding, diseño y desarrollo web con una dirección visual premium."
  url="https://sqstudio.es/contacto"
>
  <section class="page-hero">
    <div class="site-shell page-hero__grid">
      <div class="space-y-6" data-reveal>
        <p class="eyebrow">Contacto</p>
        <h1 class="section-title text-[var(--sq-cream)]">Diseñemos una presencia más precisa, más fuerte y más contemporánea.</h1>
        <p class="section-copy">
          Cuéntanos qué necesitas construir o rediseñar. Responderemos con foco estratégico, criterio visual
          y una propuesta realista para llevar la marca a un estándar superior.
        </p>
      </div>

      <div class="page-hero__panel" data-reveal>
        <div class="editorial-list">
          <div class="editorial-item">
            <strong>Email</strong>
            <p>saraquintanadg@gmail.com</p>
          </div>
          <div class="editorial-item">
            <strong>Base</strong>
            <p>Santa Cruz de Tenerife · Proyectos locales y remotos.</p>
          </div>
          <div class="editorial-item">
            <strong>Enfoque</strong>
            <p>Branding, dirección de arte, desarrollo web y sistemas visuales.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-pad">
    <div class="site-shell grid gap-8 md:grid-cols-[0.85fr_1.15fr]">
      <div class="section-frame p-6 md:p-8" data-reveal>
        <p class="eyebrow">Antes de empezar</p>
        <div class="editorial-list mt-6">
          <div class="editorial-item">
            <strong>Qué buscas</strong>
            <p>Rediseño, lanzamiento, nueva web, identidad visual o dirección creativa de campaña.</p>
          </div>
          <div class="editorial-item">
            <strong>Qué revisamos</strong>
            <p>Tono, percepción actual, fricción visual, contenido y necesidades técnicas reales.</p>
          </div>
          <div class="editorial-item">
            <strong>Qué entregamos</strong>
            <p>Un plan más claro, una presencia más sólida y una ejecución con criterio de marca.</p>
          </div>
        </div>
      </div>

      <div class="section-frame p-6 md:p-8" data-reveal>
        <form class="contact-form" action="https://formsubmit.co/saraquintanadg@gmail.com" method="POST">
          <input type="text" name="name" placeholder="Nombre" required />
          <input type="email" name="email" placeholder="Correo electrónico" required />
          <textarea name="message" rows="7" placeholder="¿Qué quieres construir o mejorar?" required></textarea>
          <input type="hidden" name="_captcha" value="false" />
          <input type="hidden" name="_next" value="https://sqstudio.es/gracias" />
          <button type="submit" class="button-primary">Enviar mensaje</button>
        </form>
      </div>
    </div>
  </section>
</Layout>
