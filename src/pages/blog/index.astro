---
import Layout from "@/layouts/Layout.astro";
import { blogPosts } from "@/data/blog";

const schemas = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "Blog SQ Studio",
    url: "https://sqstudio.es/blog",
    description: "Artículos de SQ Studio sobre branding estratégico, diseño web profesional, desarrollo web a medida y diseño gráfico para negocios.",
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Inicio", item: "https://sqstudio.es/" },
      { "@type": "ListItem", position: 2, name: "Blog", item: "https://sqstudio.es/blog" },
    ],
  },
];
---

<Layout
  title="Blog sobre branding, diseño web y diseño gráfico | SQ Studio"
  description="Artículos de SQ Studio sobre branding estratégico, diseño web profesional, desarrollo web a medida y diseño gráfico para negocios."
  url="https://sqstudio.es/blog"
  schemas={schemas}
>
  <section class="page-hero">
    <div class="site-shell page-hero__grid">
      <div class="space-y-6" data-reveal>
        <p class="eyebrow">Blog</p>
        <h1 class="section-title text-[var(--sq-cream)]">Reflexiones y guías sobre branding, diseño web y dirección visual.</h1>
        <p class="section-copy">
          Aquí reunimos artículos sobre branding estratégico, diseño web profesional, desarrollo web a medida
          y decisiones visuales que influyen en la claridad, la percepción y la consistencia de una marca.
        </p>
      </div>

      <div class="page-hero__panel" data-reveal>
        <div class="editorial-list">
          <div class="editorial-item">
            <strong>Branding</strong>
            <p>Ideas para construir marcas más claras, coherentes y reconocibles.</p>
          </div>
          <div class="editorial-item">
            <strong>Web</strong>
            <p>Contenidos sobre estructura, diseño y decisiones que mejoran la experiencia digital.</p>
          </div>
          <div class="editorial-item">
            <strong>Diseño</strong>
            <p>Notas sobre criterio visual, dirección de arte y sistemas aplicados a proyectos reales.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-pad">
    <div class="site-shell grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {blogPosts.map((post) => (
        <article class="surface-card" data-reveal>
          <p class="media-card__label">{post.eyebrow}</p>
          <h2 class="mt-4 text-3xl font-bold uppercase leading-none tracking-[-0.05em] text-[var(--sq-cream)]">
            <a href={`/blog/${post.slug}`}>{post.title}</a>
          </h2>
          <p class="mt-5">{post.excerpt}</p>
          <div class="mt-6 flex items-center justify-between gap-4 text-xs uppercase tracking-[0.14em] text-[rgba(254,251,164,0.52)]">
            <span>{post.readingTime}</span>
            <span>{post.publishDate}</span>
          </div>
          <div class="mt-8">
            <a href={`/blog/${post.slug}`} class="button-secondary">Leer artículo</a>
          </div>
        </article>
      ))}
    </div>
  </section>
</Layout>
