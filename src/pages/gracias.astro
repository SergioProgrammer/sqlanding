---
import Layout from "@/layouts/Layout.astro";
---

<Layout
  title="Gracias | SQ Studio"
  description="Mensaje recibido correctamente."
  url="https://sqstudio.es/gracias"
>
  <section class="page-hero">
    <div class="site-shell">
      <div class="section-frame p-8 md:p-12" data-reveal>
        <p class="eyebrow">Mensaje recibido</p>
        <h1 class="section-title mt-6 text-[var(--sq-cream)]">Gracias. Revisaremos tu mensaje y responderemos pronto.</h1>
        <p class="section-copy mt-6">
          Mientras tanto, puedes seguir explorando proyectos o volver al inicio.
        </p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a href="/" class="button-primary">Volver al inicio</a>
          <a href="/proyectos" class="button-secondary">Ver proyectos</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
