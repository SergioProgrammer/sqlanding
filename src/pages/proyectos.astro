const featuredProjects = projects.slice(0, 3);
---

<Layout
  title="Proyectos | SQ Studio"
  description="Selección de proyectos de SQ Studio en cartelería, web, editorial, infografía e identidad visual."
  url="https://sqstudio.es/proyectos"
>
  <section class="page-hero">
    <div class="site-shell page-hero__grid">
      <div class="space-y-6" data-reveal>
        <p class="eyebrow">Proyectos</p>
        <h1 class="section-title text-[var(--sq-cream)]">Portfolio aplicado a cartelería, web, editorial e identidad visual.</h1>
        <p class="section-copy">
          Una selección de proyectos desarrollados para instituciones, congresos, marcas y programas
          formativos, manteniendo el mismo lenguaje visual y la estructura actual de la web.
        </p>
      </div>
      <div class="page-hero__panel" data-reveal>
        <div class="editorial-list">
          <div class="editorial-item">
            <strong>Cartelería</strong>
            <p>Piezas para jornadas, eventos y campañas con jerarquía clara y adaptación a distintos soportes.</p>
          </div>
          <div class="editorial-item">
            <strong>Editorial y maquetación</strong>
            <p>Informes, manuales, presentaciones e infografías con foco en claridad técnica y lectura fluida.</p>
          </div>
          <div class="editorial-item">
            <strong>Web e identidad</strong>
            <p>Diseño digital y sistemas visuales que conectan presencia de marca y funcionalidad.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-pad pt-0">
    <div class="site-shell grid gap-6 md:grid-cols-[1.2fr_0.8fr]">
      <a href={`#${featuredProjects[0].id}`} class="media-card" data-reveal>
        <img src={featuredProjects[0].images[0]} alt={`${featuredProjects[0].title} - ${featuredProjects[0].discipline}`} loading="eager" />
        <div class="media-card__overlay">
          <span class="media-card__label">{featuredProjects[0].discipline}</span>
          <h2 class="media-card__title">{featuredProjects[0].title}</h2>
        </div>
      </a>

      <div class="grid gap-6">
        {featuredProjects.slice(1).map((project) => (
          <a href={`#${project.id}`} class="media-card min-h-[13rem]" data-reveal>
            <img src={project.images[0]} alt={`${project.title} - ${project.discipline}`} loading="lazy" />
            <div class="media-card__overlay">
              <span class="media-card__label">{project.discipline}</span>
              <h2 class="media-card__title">{project.title}</h2>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section-pad">
    <div class="site-shell grid gap-6">
      {projects.map((project) => (
        <article id={project.id} class="section-frame p-6 md:p-8" data-reveal>
          <div class="grid gap-8 md:grid-cols-[0.9fr_1.1fr] md:items-start">
            <div class="space-y-5">
              <p class="eyebrow">{project.discipline}</p>
              <div class="space-y-3">
                <h2 class="section-title text-[var(--sq-cream)]">{project.title}</h2>
                <p class="section-copy max-w-none">
                  <strong class="text-[var(--sq-cream)]">Client:</strong> {project.client}
                </p>
              </div>
              <p class="section-copy">{project.summary}</p>
            </div>

            <div class="editorial-list">
              {project.paragraphs.map((paragraph) => (
                <div class="editorial-item">
                  <p>{paragraph}</p>
                </div>
              ))}
            </div>
          </div>

          <div class={`mt-8 grid gap-6 ${project.images.length === 1 ? "md:grid-cols-1" : project.images.length === 2 ? "md:grid-cols-2" : "md:grid-cols-2 xl:grid-cols-3"}`}>
            {project.images.map((image, imageIndex) => (
              <article class="media-card min-h-[18rem]">
                <img src={image} alt={`${project.title} imagen ${imageIndex + 1}`} loading="lazy" />
                <div class="media-card__overlay">
                  <span class="media-card__label">{project.discipline}</span>
                  <h3 class="media-card__title">{project.title}</h3>
                </div>
              </article>
            ))}
          </div>
        </article>
      ))}
    </div>
  </section>
</Layout>
