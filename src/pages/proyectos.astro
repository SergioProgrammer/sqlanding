---
import Layout from "@/layouts/Layout.astro";
import designImage from "@/assets/2.webp";
import webImage from "@/assets/web.png";
import socialImage from "@/assets/8.webp";
---

<Layout
  title="Proyectos | SQ Studio"
  description="Proyectos y verticales de SQ Studio: branding, diseño gráfico, web y contenido visual."
  url="https://sqstudio.es/proyectos"
>
  <section class="page-hero">
    <div class="site-shell page-hero__grid">
      <div class="space-y-6" data-reveal>
        <p class="eyebrow">Proyectos</p>
        <h1 class="section-title text-[var(--sq-cream)]">Trabajo visual con estructura, tensión y una lectura más editorial.</h1>
        <p class="section-copy">
          Reordenamos el portfolio para que se entienda mejor qué hace SQ Studio y cómo se traduce eso
          en piezas, experiencias y sistemas de marca más sólidos.
        </p>
      </div>
      <div class="page-hero__panel" data-reveal>
        <div class="editorial-list">
          <div class="editorial-item">
            <strong>Diseño</strong>
            <p>Identidad, editorial, campañas y soportes con más intención compositiva.</p>
          </div>
          <div class="editorial-item">
            <strong>Web</strong>
            <p>Interfaces que equilibran claridad, rendimiento y presencia premium.</p>
          </div>
          <div class="editorial-item">
            <strong>Contenido</strong>
            <p>Piezas para redes y lanzamientos que sostienen la percepción de la marca.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-pad">
    <div class="site-shell grid gap-6">
      <a href="/diseño" class="media-card" data-reveal>
        <img src={designImage.src} alt="Proyecto de diseño gráfico" loading="lazy" />
        <div class="media-card__overlay">
          <span class="media-card__label">Diseño gráfico</span>
          <h2 class="media-card__title">Sistemas visuales y piezas con peso de marca.</h2>
        </div>
      </a>

      <div class="grid gap-6 md:grid-cols-2">
        <a href="/web" class="media-card" data-reveal>
          <img src={webImage.src} alt="Proyecto web" loading="lazy" />
          <div class="media-card__overlay">
            <span class="media-card__label">Desarrollo web</span>
            <h2 class="media-card__title">Experiencias digitales con orden y presencia.</h2>
          </div>
        </a>

        <a href="/redes" class="media-card" data-reveal>
          <img src={socialImage.src} alt="Proyecto visual para redes" loading="lazy" />
          <div class="media-card__overlay">
            <span class="media-card__label">Contenido y campañas</span>
            <h2 class="media-card__title">Narrativa visual adaptable a cada canal.</h2>
          </div>
        </a>
      </div>
    </div>
  </section>
</Layout>
