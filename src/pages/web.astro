---
import Layout from "@/layouts/Layout.astro";
import webImage from "@/assets/web.png";
import screenA from "@/assets/diseño/web1.png";
import screenB from "@/assets/2.webp";

const blocks = [
  {
    title: "Arquitectura clara",
    copy: "Reordenamos el contenido para que la propuesta se entienda en segundos y el recorrido sea más editorial que corporativo.",
  },
  {
    title: "Diseño + desarrollo",
    copy: "Evitamos la brecha entre una interfaz bonita y una implementación mediocre. Ambas capas se diseñan juntas.",
  },
  {
    title: "Rendimiento y SEO",
    copy: "Cada decisión visual se mantiene ligera para no sacrificar velocidad, indexación ni accesibilidad.",
  },
];
---

<Layout
  title="Desarrollo web | SQ Studio"
  description="Diseño y desarrollo web premium para marcas que buscan una presencia más contemporánea."
  url="https://sqstudio.es/web"
>
  <section class="page-hero">
    <div class="site-shell page-hero__grid">
      <div class="space-y-6" data-reveal>
        <p class="eyebrow">Web</p>
        <h1 class="section-title text-[var(--sq-cream)]">Interfaces sobrias, cinematográficas y construidas para convertir mejor.</h1>
        <p class="section-copy">
          La nueva dirección visual aplica a la capa digital: más aire, tipografía con autoridad, transición suave
          entre bloques y un discurso más breve para que la experiencia se sienta superior.
        </p>
      </div>
      <div class="page-hero__panel" data-reveal>
        <div class="editorial-list">
          {blocks.map((block) => (
            <div class="editorial-item">
              <strong>{block.title}</strong>
              <p>{block.copy}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section-pad">
    <div class="site-shell grid gap-6 md:grid-cols-[1.15fr_0.85fr]">
      <article class="media-card" data-reveal>
        <img src={webImage.src} alt="Pantalla principal de proyecto web" loading="lazy" />
        <div class="media-card__overlay">
          <span class="media-card__label">Experiencia digital</span>
          <h2 class="media-card__title">Hero full screen, navegación fija y ritmo visual más maduro.</h2>
        </div>
      </article>

      <div class="grid gap-6">
        <article class="media-card min-h-[16rem]" data-reveal>
          <img src={screenA.src} alt="Detalle de diseño web" loading="lazy" />
          <div class="media-card__overlay">
            <span class="media-card__label">Detalle</span>
            <h2 class="media-card__title">Interacción limpia y estado hover refinado.</h2>
          </div>
        </article>

        <article class="section-frame p-6 md:p-8" data-reveal>
          <p class="eyebrow">Sistema</p>
          <p class="mt-6 text-3xl font-bold uppercase leading-none tracking-[-0.05em] text-[var(--sq-cream)] md:text-5xl">
            Menos bloques pequeños. Más escenas amplias con jerarquía real.
          </p>
          <p class="section-copy mt-6">
            Este cambio hace que la web se acerque más a una marca premium y menos a una landing genérica.
          </p>
        </article>
      </div>
    </div>

    <div class="site-shell mt-6">
      <article class="media-card min-h-[24rem]" data-reveal>
        <img src={screenB.src} alt="Diseño visual aplicado en entorno digital" loading="lazy" />
        <div class="media-card__overlay">
          <span class="media-card__label">Conversión</span>
          <h2 class="media-card__title">Claridad de mensaje, mejor contraste y CTA con más peso.</h2>
        </div>
      </article>
    </div>
  </section>
</Layout>
