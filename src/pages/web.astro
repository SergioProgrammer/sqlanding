---
import Layout from "@/layouts/Layout.astro";
---

<Layout
  title="Diseño web profesional y desarrollo web a medida | SQ Studio"
  description="Diseño web profesional y desarrollo web a medida para marcas y negocios que necesitan una web clara, rápida y orientada a conversión."
  url="https://sqstudio.es/web"
  canonical="https://sqstudio.es/diseno-web"
  robots="noindex, follow"
  redirectTo="/diseno-web"
>
  <section class="page-hero">
    <div class="site-shell">
      <div class="section-frame p-8 md:p-12" data-reveal>
        <p class="eyebrow">Redirección</p>
        <h1 class="section-title mt-6 text-[var(--sq-cream)]">Esta página se ha movido a diseño web profesional.</h1>
        <p class="section-copy mt-6">
          Si no eres redirigido automáticamente, puedes continuar desde la nueva URL principal del servicio.
        </p>
        <div class="mt-8">
          <a href="/diseno-web" class="button-primary">Ir a diseño web profesional</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
