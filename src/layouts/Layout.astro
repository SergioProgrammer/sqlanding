---
import "../styles/global.css";
import CookieBanner from "../components/CookieBanner.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";

interface Props {
  title?: string;
  description?: string;
  ogTitle?: string;
  ogDescription?: string;
  url?: string;
  canonical?: string;
  image?: string;
  robots?: string;
  ogType?: string;
  schemas?: Record<string, unknown>[];
  redirectTo?: string;
}

const {
  title = "SQ Studio | Diseño, branding y experiencias digitales premium",
  description = "SQ Studio diseña marcas, webs y sistemas visuales con una dirección creativa precisa, contemporánea y orientada a conversión.",
  ogTitle = title,
  ogDescription = description,
  url = Astro.url ? new URL(Astro.url.pathname, Astro.site ?? "https://sqstudio.es").toString() : "https://sqstudio.es/",
  canonical = url,
  image = new URL("/og-image.svg", Astro.site ?? "https://sqstudio.es").toString(),
  robots = "index, follow",
  ogType = "website",
  schemas = [],
  redirectTo,
} = Astro.props;

const siteUrl = Astro.site?.toString() ?? "https://sqstudio.es";
const baseSchemas = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "SQ Studio",
    url: siteUrl,
    description,
    inLanguage: "es-ES",
  },
  {
    "@context": "https://schema.org",
    "@type": "ProfessionalService",
    name: "SQ Studio",
    url: siteUrl,
    image,
    description,
    areaServed: ["ES", "Remote"],
    address: {
      "@type": "PostalAddress",
      addressLocality: "Santa Cruz de Tenerife",
      addressCountry: "ES",
    },
    sameAs: ["https://instagram.com/sqstudiodm"],
    serviceType: [
      "Branding estratégico",
      "Diseño web profesional",
      "Desarrollo web a medida",
      "Diseño gráfico profesional",
    ],
  },
];

const allSchemas = [...baseSchemas, ...schemas];
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/logo-stack.svg" />
    <link rel="canonical" href={canonical} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <meta name="author" content="SQ Studio" />
    {redirectTo && <meta http-equiv="refresh" content={`0;url=${redirectTo}`} />}
    <meta property="og:site_name" content="SQ Studio" />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={image} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={image} />
    {allSchemas.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
  </head>
  <body>
    <a class="skip-link" href="#content">Saltar al contenido</a>
    <SiteHeader />
    <main id="content">
      <slot />
    </main>
    <SiteFooter />
    <CookieBanner />
    <script is:inline>
      const observer = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              observer.unobserve(entry.target);
            }
          }
        },
        { threshold: 0.16, rootMargin: "0px 0px -10% 0px" },
      );

      document.querySelectorAll("[data-reveal]").forEach((element) => observer.observe(element));

      const header = document.querySelector("[data-site-header]");
      const setHeaderState = () => {
        if (!header) return;
        header.classList.toggle("is-scrolled", window.scrollY > 24);
      };

      setHeaderState();
      window.addEventListener("scroll", setHeaderState, { passive: true });

      document.querySelectorAll("details[data-nav-menu] a").forEach((link) => {
        link.addEventListener("click", () => {
          link.closest("details")?.removeAttribute("open");
        });
      });

      const cookieBanner = document.querySelector("[data-cookie-banner]");
      const acceptAllCookiesButton = document.querySelector("[data-cookie-accept-all]");
      const saveCookiesButton = document.querySelector("[data-cookie-save]");
      const rejectCookiesButton = document.querySelector("[data-cookie-reject]");
      const cookieOptions = document.querySelectorAll("[data-cookie-option]");
      const cookieConsentKey = "sqstudio-cookie-consent";
      const defaultConsent = {
        necessary: true,
        preferences: false,
        analytics: false,
        marketing: false,
      };

      const hideCookieBanner = () => {
        if (!cookieBanner) return;
        cookieBanner.setAttribute("hidden", "");
      };

      const showCookieBanner = () => {
        if (!cookieBanner) return;
        cookieBanner.removeAttribute("hidden");
      };

      const applyConsentToInputs = (consent) => {
        cookieOptions.forEach((option) => {
          const key = option.getAttribute("data-cookie-option");
          if (!key) return;
          option.checked = Boolean(consent[key]);
        });
      };

      const getConsentFromInputs = () => ({
        necessary: true,
        preferences: Boolean(document.querySelector('[data-cookie-option="preferences"]')?.checked),
        analytics: Boolean(document.querySelector('[data-cookie-option="analytics"]')?.checked),
        marketing: Boolean(document.querySelector('[data-cookie-option="marketing"]')?.checked),
      });

      const persistConsent = (consent) => {
        try {
          window.localStorage.setItem(cookieConsentKey, JSON.stringify(consent));
        } catch {}
      };

      try {
        const storedConsent = window.localStorage.getItem(cookieConsentKey);
        if (!storedConsent) {
          applyConsentToInputs(defaultConsent);
          showCookieBanner();
        } else {
          applyConsentToInputs({ ...defaultConsent, ...JSON.parse(storedConsent) });
        }
      } catch {
        applyConsentToInputs(defaultConsent);
        showCookieBanner();
      }

      acceptAllCookiesButton?.addEventListener("click", () => {
        const consent = {
          necessary: true,
          preferences: true,
          analytics: true,
          marketing: true,
        };
        applyConsentToInputs(consent);
        persistConsent(consent);
        hideCookieBanner();
      });

      saveCookiesButton?.addEventListener("click", () => {
        persistConsent(getConsentFromInputs());
        hideCookieBanner();
      });

      rejectCookiesButton?.addEventListener("click", () => {
        applyConsentToInputs(defaultConsent);
        persistConsent(defaultConsent);
        hideCookieBanner();
      });
    </script>
  </body>
</html>
